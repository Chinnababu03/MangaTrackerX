# MongoDB Atlas connection
MONGODB_USERNAME=your_atlas_username
MONGODB_PASSWORD=your_atlas_password
MONGODB_DATABASE=your_database_name
MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net   # from your Atlas connection string
MONGODB_APP_NAME=MangaTrackerX               # optional — shown in Atlas activity logs

# Collection names (change only if you need different names in your DB)
LINKS=LINKS
PAGESOURCE=PAGESOURCE
MANGA_DATA=MANGA_DATA
