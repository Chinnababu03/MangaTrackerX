# MongoDB Atlas
MONGODB_USERNAME=your_atlas_username
MONGODB_PASSWORD=your_atlas_password
MONGODB_DATABASE=your_database_name
MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
MONGODB_APP_NAME=MangaTrackerX-API

# Collection names (must match what the pipeline wrote to)
MANGA_DATA=MANGA_DATA

# CORS — comma-separated list of allowed frontend origins
# Use * for development, restrict to your frontend URL in production
# e.g. ALLOWED_ORIGINS=https://mangax-frontend-xxxx.run.app
ALLOWED_ORIGINS=*
